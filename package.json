{
  "name": "dreamine2api",
  "version": "2.0.0",
  "description": "Dreamina OpenAI 兼容 API + Nuxt 管理面板（config.toml + SQLite）",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "legacy:dev": "tsup src/index.ts --format cjs,esm --sourcemap --dts --publicDir public --watch --onSuccess \"node --enable-source-maps --no-node-snapshot dist/index.js\"",
    "legacy:build": "tsup src/index.ts --format cjs,esm --sourcemap --dts --clean --publicDir public",
    "legacy:start": "node --enable-source-maps --no-node-snapshot dist/index.js",
    "scrape:models": "node scripts/scrape-dreamina-models.mjs",
    "fetch:models": "node scripts/fetch-models-with-session.mjs",
    "build:catalog": "node scripts/build-model-catalog.mjs",
    "type-check": "nuxt typecheck"
  },
  "author": "Dreamina API Team",
  "license": "GPL-3.0",
  "dependencies": {
    "@nuxt/ui": "^3.0.0",
    "axios": "^1.6.7",
    "better-sqlite3": "^11.8.1",
    "colors": "^1.4.0",
    "crc-32": "^1.2.2",
    "cron": "^3.1.6",
    "date-fns": "^3.3.1",
    "eventsource-parser": "^1.1.2",
    "form-data": "^4.0.0",
    "fs-extra": "^11.2.0",
    "https-proxy-agent": "^7.0.6",
    "koa": "^2.15.0",
    "koa-body": "^5.0.0",
    "koa-range": "^0.3.0",
    "koa-router": "^12.0.1",
    "koa2-cors": "^2.0.6",
    "lodash": "^4.17.21",
    "mime": "^4.0.1",
    "minimist": "^1.2.8",
    "nuxt": "^3.16.0",
    "randomstring": "^1.3.0",
    "semver": "^7.7.2",
    "smol-toml": "^1.3.1",
    "socks-proxy-agent": "^8.0.5",
    "uuid": "^9.0.1",
    "vue": "^3.5.13",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/lodash": "^4.14.202",
    "@types/mime": "^3.0.4",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vue-tsc": "^3.3.5"
  }
}
